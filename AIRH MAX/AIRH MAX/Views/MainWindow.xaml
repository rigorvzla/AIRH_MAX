<Window x:Name="window"
        x:Class="AIRH_MAX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ba="clr-namespace:AIRH_MAX.ControlUsuario.Banner"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Height="700"
        Width="900"
        Background="Transparent"
        Foreground="{DynamicResource PrimaryText}"
        Loaded="Window_Loaded"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ScrollBarModern.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="15"
            Background="{DynamicResource PrimaryColor}">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <ba:BannerMain Grid.Row="0"
                           FontSize="14"
                           Foreground="{DynamicResource PrimaryText}"
                           Margin="5" />
            <RadioButton Grid.Column="1"
                         HorizontalAlignment="Right"
                         Click="RadioButton_Click"
                         Margin="0,0,10,0"
                         FontSize="20"
                         Width="25"
                         Style="{StaticResource RadioButtomTheme}"
                         Foreground="{DynamicResource PrimaryText}">
                <materialDesign:PackIcon Kind="Close"
                                         Width="23"
                                         Height="25"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource PrimaryText}"
                                         ToolTip="Cerrar asistente" />
            </RadioButton>
            <Border CornerRadius="0,10,0,0"
                    Grid.Row="1"
                    Background="{DynamicResource SecondaryColor}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="60" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">

                        <StackPanel>

                            <RadioButton ToolTip="Pantalla de inicio"
                                         Margin="5,5,0,5"
                                         Height="40"
                                         Width="190"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}"
                                         FontSize="20"
                                         Name="BtnPrincipal"
                                         Click="BtnPrincipal_Click">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Home" />
                                        <TextBlock Text="Inicio"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton Width="190"
                                         Height="40"
                                         FontSize="20"
                                         Margin="5,0,0,5"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Click="Chat_Click">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="MessageText" />
                                        <TextBlock Text="Chat"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton ToolTip="Correo Electronico"
                                         Margin="5,5,0,5"
                                         Height="40"
                                         Width="190"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}"
                                         FontSize="20"
                                         Name="BtnCorreo"
                                         Click="BtnCorreo_Click">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Gmail" />
                                        <TextBlock Text="Correo Electronico"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton ToolTip="Información del sistema en tiempo real"
                                         Click="BtnSistema"
                                         Height="40"
                                         Margin="5,0,0,5"
                                         Width="190"
                                         FontSize="20"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Name="btnCS"
                                         Style="{StaticResource RadioButtomTheme}">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Computer" />
                                        <TextBlock Text="Monitor de Equipo"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton ToolTip="Verifica si hay algun cambio en los directorios asignados"
                                         Height="40"
                                         Margin="5,0,0,5"
                                         Width="190"
                                         Name="BtnMonitor"
                                         Foreground="{DynamicResource PrimaryText}"
                                         FontSize="20"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Click="BtnMonitor_Click">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="MagnifyScan" />
                                        <TextBlock Text="Monitor de Directorio"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton Click="BtnGamer_Click"
                                         Height="40"
                                         Margin="5,0,0,5"
                                         Width="190"
                                         FontSize="20"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnGam"
                                         ToolTip="Modulo de acción automatica para juegos">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Gamepad" />
                                        <TextBlock Text="Modo Juego"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton Click="BtnAgenda_Click"
                                         Foreground="{DynamicResource PrimaryText}"
                                         FontSize="20"
                                         Width="190"
                                         Margin="5,0,0,5"
                                         Height="40"
                                         Name="btnAgenda"
                                         ToolTip="Calendario - Agenda - Tarea Programada"
                                         Style="{StaticResource RadioButtomTheme}">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Notebook" />
                                        <TextBlock Text="Organizador"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton Click="BtnComandos"
                                         Width="190"
                                         Height="40"
                                         FontSize="20"
                                         Margin="5,0,0,5"
                                         ToolTip="Comandos"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnCMD">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Terminal" />
                                        <TextBlock Text="Comandos"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton Click="BtnArduino"
                                         Width="190"
                                         Height="40"
                                         FontSize="20"
                                         Margin="5,0,0,5"
                                         ToolTip="Comandos"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnArduino">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Chip" />
                                        <TextBlock Text="Arduino"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>

                            <RadioButton Click="BtnHerramientas"
                                         Width="190"
                                         Height="40"
                                         ToolTip="Herramientas"
                                         FontSize="20"
                                         Margin="5,0,0,5"
                                         Name="btnHER"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Toolbox" />
                                        <TextBlock Text="Herramientas"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton Click="BtnMenuVideo"
                                         Width="190"
                                         Height="40"
                                         ToolTip="Menú Videos"
                                         FontSize="20"
                                         Margin="5,0,0,5"
                                         Name="btnMV"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Video" />
                                        <TextBlock Text="Menú Videos"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton Click="BtnHerramientasM"
                                         Width="190"
                                         Height="40"
                                         FontSize="20"
                                         Margin="5,0,0,5"
                                         ToolTip="Herramientas Multimedia"
                                         Name="btnHERM"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Style="{StaticResource RadioButtomTheme}">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="StarSettings" />
                                        <TextBlock Text="Multimedia"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton Click="BtnConfiguracion"
                                         Margin="5,0,0,5"
                                         Width="190"
                                         Foreground="{DynamicResource PrimaryText}"
                                         FontSize="20"
                                         Height="40"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnCFG"
                                         ToolTip="Configuración">
                                <RadioButton.Content>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="20,0"
                                                Width="180">
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center"
                                                                 Kind="Gear" />
                                        <TextBlock Text="Configuración"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </StackPanel>
                                </RadioButton.Content>
                            </RadioButton>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>


                        </Grid>
                    </StackPanel>
                    <StackPanel Grid.Row="3"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">

                        <Border CornerRadius="25"
                                Width="35"
                                Height="35"
                                Background="{DynamicResource PrimaryColor}">

                            <RadioButton ToolTip="Enviar comentario / Reportar Bug"
                                         Width="30"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Height="30"
                                         Click="Button_Click"
                                         BorderBrush="{x:Null}"
                                         Foreground="{x:Null}">
                                <RadioButton.Background>
                                    <ImageBrush ImageSource="/PNG/AIRH.png"
                                                Stretch="Uniform" />
                                </RadioButton.Background>
                            </RadioButton>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <Label Content="AV-AIRH MAX"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontWeight="SemiBold"
                                   Margin="0,-5,0,-5" />
                            <Label Foreground="{DynamicResource PrimaryText}"
                                   FontWeight="Thin"
                                   FontSize="10"
                                   Name="LabelVersion"
                                   Margin="0,-7,0,-5" />

                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Grid Grid.Row="0"
                  Grid.RowSpan="2"
                  Grid.Column="1"
                  Margin="30,40,30,0"
                  Name="GridPrincipal">

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border CornerRadius="10"
                        BorderThickness="1">
                    <Border.BorderBrush>
                        <RadialGradientBrush>
                            <GradientStop Color="White"
                                          Offset="0.012" />
                            <GradientStop Color="#FFA5B6D2"
                                          Offset="1" />
                        </RadialGradientBrush>
                    </Border.BorderBrush>
                    <Border.Background>
                        <RadialGradientBrush SpreadMethod="Reflect"
                                             Opacity="0.4"
                                             MappingMode="RelativeToBoundingBox">
                            <GradientStop Color="#FF62629A" />
                            <GradientStop Color="#FF39395A"
                                          Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>

                    <Grid HorizontalAlignment="Stretch"
                          Opacity="0.6"
                          Margin="8,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center"
                                    ToolTip="Usa imagenes de buena calidad"
                                    DragEnter="Imagen_DragEnter"
                                    Drop="imagenTexto_Drop"
                                    PreviewDragOver="ImagenDrop_PreviewDragOver"
                                    AllowDrop="True">
                            <TextBlock Text="Extraer Texto"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <materialDesign:PackIcon Kind="TextBox"
                                                     Width="23"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}"
                                                     ToolTip="Extrae el texto de una imagen" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    AllowDrop="True"
                                    Drop="ImagenDrop_Drop"
                                    DragEnter="Imagen_DragEnter"
                                    PreviewDragOver="ImagenDrop_PreviewDragOver"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Convertir a JPG"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <materialDesign:PackIcon Kind="FileImage"
                                                     Width="23"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}"
                                                     ToolTip="Convierte imagen a JPG" />
                        </StackPanel>

                        <StackPanel  VerticalAlignment="Center"
                                     DragEnter="Imagen_DragEnter"
                                     PreviewDragOver="ImagenDrop_PreviewDragOver"
                                     Drop="mp3Box_Drop"
                                     AllowDrop="True"
                                     Grid.Column="2">
                            <TextBlock Text="Convertir a MP3"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <materialDesign:PackIcon Kind="FileMusic"
                                                     Width="23"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}"
                                                     ToolTip="Convierte audio a MP3" />
                        </StackPanel>

                        <StackPanel   VerticalAlignment="Center"
                                      Drop="mp4Box_Drop"
                                      DragEnter="Imagen_DragEnter"
                                      PreviewDragOver="ImagenDrop_PreviewDragOver"
                                      AllowDrop="True"
                                      Grid.Column="3">
                            <TextBlock Text="Convertir a MP4"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <materialDesign:PackIcon Kind="FileVideo"
                                                     Width="23"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}"
                                                     ToolTip="Convierte audio a MP4" />
                        </StackPanel>

                        <StackPanel VerticalAlignment="Center"
                                    Name="CbTelegram"
                                    Drop="CbTelegram_Drop"
                                    DragEnter="Imagen_DragEnter"
                                    PreviewDragOver="ImagenDrop_PreviewDragOver"
                                    AllowDrop="True"
                                    Grid.Column="4">
                            <TextBlock Text="Enviar a Telegram"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <materialDesign:PackIcon Kind="ArrowUpBox"
                                                     Width="23"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}"
                                                     ToolTip="Envia archivos para ti en Telegram" />
                        </StackPanel>

                    </Grid>
                </Border>
                <Grid Grid.Column="1"
                      Grid.Row="1"
                      Opacity="0.6">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="450" />
                        <RowDefinition Height="60" />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                    </Grid.ColumnDefinitions>

                    <Border CornerRadius="10"
                            BorderThickness="1"
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,20,20,0">
                        <Border.BorderBrush>
                            <RadialGradientBrush>
                                <GradientStop Color="White"
                                              Offset="0.012" />
                                <GradientStop Color="#FFA5B6D2"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <RadialGradientBrush SpreadMethod="Reflect"
                                                 Opacity="0.4"
                                                 MappingMode="RelativeToBoundingBox">
                                <GradientStop Color="#FF62629A" />
                                <GradientStop Color="#FF39395A"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>

                        <ListView Name="TextBoxVisual"
                                  Cursor="Arrow"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False"
                                  ItemContainerStyle="{StaticResource ChatItem}"
                                  AllowDrop="False"
                                  Focusable="False"
                                  Background="Transparent">

                            <!-- ¡CORREGIR LA ORIENTACIÓN! -->
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                        </ListView>

                    </Border>
                    <Border Grid.Row="1"
                            Margin="0,15,22,15"
                            CornerRadius="5">

                        <Border.BorderBrush>
                            <RadialGradientBrush>
                                <GradientStop Color="White"
                                              Offset="0.012" />
                                <GradientStop Color="#FFA5B6D2"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <RadialGradientBrush SpreadMethod="Reflect"
                                                 Opacity="0.6"
                                                 MappingMode="RelativeToBoundingBox">
                                <GradientStop Color="#FF62629A" />
                                <GradientStop Color="#FFADADAD"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Margin="10,0,5,0"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}"
                                                     HorizontalAlignment="Center"
                                                     Kind="Chat" />
                            <TextBox Width="370"
                                     Name="TextBoxEnlace"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource PrimaryText}"
                                     SelectionBrush="{DynamicResource SecondaryText}"
                                     BorderBrush="Transparent"
                                     KeyDown="TextBoxEnlace_KeyDown"
                                     materialDesign:HintAssist.Hint="Chat IA"
                                     Style="{StaticResource MaterialDesignTextBoxBase}" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="10"
                            BorderThickness="1"
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,20,20">
                        <Border.BorderBrush>
                            <RadialGradientBrush>
                                <GradientStop Color="White"
                                              Offset="0.012" />
                                <GradientStop Color="#FFA5B6D2"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <RadialGradientBrush SpreadMethod="Reflect"
                                                 Opacity="0.4"
                                                 MappingMode="RelativeToBoundingBox">
                                <GradientStop Color="#FF62629A" />
                                <GradientStop Color="#FF39395A"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>

                        <ListView Name="ListBoxLog"
                                  FontWeight="Regular"
                                  Cursor="Arrow"
                                  ItemContainerStyle="{StaticResource LogItem}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.CanContentScroll="False"
                                  AllowDrop="False"
                                  Focusable="False">

                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                        </ListView>
                    </Border>
                    <Border CornerRadius="10"
                            BorderThickness="1"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            Grid.Column="1"
                            Margin="0,20,0,20">
                        <Border.BorderBrush>
                            <RadialGradientBrush>
                                <GradientStop Color="White"
                                              Offset="0.012" />
                                <GradientStop Color="#FFA5B6D2"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <RadialGradientBrush SpreadMethod="Reflect"
                                                 Opacity="0.4"
                                                 MappingMode="RelativeToBoundingBox">
                                <GradientStop Color="#FF62629A" />
                                <GradientStop Color="#FF39395A"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>

                        <StackPanel>
                            <materialDesign:ColorZone Margin="0,5,5,0"
                                                      Background="Transparent"
                                                      Foreground="{DynamicResource PrimaryText}">
                                <DockPanel>
                                    <materialDesign:PopupBox DockPanel.Dock="Right"
                                                             PlacementMode="BottomAndAlignRightEdges">
                                        <StackPanel    Background="{DynamicResource SecondaryColor}">
                                            <RadioButton Height="40"
                                                         Visibility="Collapsed"
                                                         Width="190"
                                                         Margin="5,0,0,5"
                                                         FontSize="20"
                                                         Name="IA_Escucha"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         Style="{StaticResource RadioButtomTheme}"
                                                         Click="escuchaSwitch_Checked">
                                                <RadioButton.Content>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="20,0"
                                                                Width="180">
                                                        <materialDesign:PackIcon Width="20"
                                                                                 Height="20"
                                                                                 x:Name="Orejita"
                                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                                 HorizontalAlignment="Center" />
                                                        <TextBlock Text="Escucha del asistente"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0"
                                                                   Foreground="{DynamicResource PrimaryText}" />
                                                    </StackPanel>
                                                </RadioButton.Content>
                                            </RadioButton>

                                            <RadioButton Height="40"
                                                         Width="190"
                                                         Margin="5,0,0,5"
                                                         Name="IA_Habla"
                                                         FontSize="20"
                                                         Foreground="{DynamicResource PrimaryText}"
                                                         Style="{StaticResource RadioButtomTheme}"
                                                         Click="hablaSwitch_Checked">
                                                <RadioButton.Content>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="20,0"
                                                                Width="180">
                                                        <materialDesign:PackIcon Width="20"
                                                                                 Height="20"
                                                                                 x:Name="Carita"
                                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                                 HorizontalAlignment="Center" />
                                                        <TextBlock Text="Elocuencia Asistente"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Left"
                                                                   VerticalAlignment="Center"
                                                                   Margin="10,0"
                                                                   Foreground="{DynamicResource PrimaryText}" />
                                                    </StackPanel>
                                                </RadioButton.Content>
                                            </RadioButton>
                                        </StackPanel>
                                    </materialDesign:PopupBox>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Margin="16,0,0,0"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Text="Preferencias" />
                                    </StackPanel>
                                </DockPanel>
                            </materialDesign:ColorZone>

                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Center">

                                <Ellipse Height="125"
                                         Width="125"
                                         Margin="10"
                                         StrokeThickness="10"
                                         Stroke="{DynamicResource PrimaryColor}"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         Grid.Row="2"
                                         Opacity="8" />

                                <Ellipse x:Name="ellipse"
                                         Width="115"
                                         Height="115"
                                         Margin="10">
                                    <Ellipse.Fill>
                                        <ImageBrush x:Name="imageBrush"
                                                    RenderOptions.BitmapScalingMode="Fant"
                                                    ImageSource="/PNG/AIRH.png" />
                                    </Ellipse.Fill>
                                </Ellipse>

                                <ProgressBar IsIndeterminate="True"
                                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Opacity="0.5"
                                             Name="pbMain"
                                             Value="100"
                                             Height="125"
                                             Width="125" />

                                <ProgressBar Visibility="Hidden"
                                             Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             Opacity="0.5"
                                             Name="pbMain2"
                                             Value="100"
                                             Height="130"
                                             Width="130" />
                            </Grid>

                            <Separator Margin="5" />

                            <StackPanel>
                                <Expander HorizontalAlignment="Stretch"
                                          Margin="0,-10,0,-5"
                                          Background="Transparent">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Información de Red"
                                                       FontSize="13"
                                                       Margin="-5"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontWeight="SemiBold" />
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Margin="0"
                                                Orientation="Vertical"
                                                TextBlock.Foreground="{DynamicResource MaterialDesignBody}">
                                        <TextBlock    Name="LabelIP"
                                                      Margin="20,-10"
                                                      Foreground="{DynamicResource PrimaryText}"
                                                      Style="{StaticResource  MaterialDesignBody2TextBlock}" />
                                    </StackPanel>
                                </Expander>
                                <Expander HorizontalAlignment="Stretch"
                                          Margin="0,0,0,-5"
                                          Background="Transparent">
                                    <Expander.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Geolocalización"
                                                       FontSize="13"
                                                       Margin="-5"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       FontWeight="SemiBold" />
                                        </DataTemplate>
                                    </Expander.HeaderTemplate>
                                    <StackPanel Margin="0"
                                                Orientation="Vertical"
                                                TextBlock.Foreground="{DynamicResource MaterialDesignBody}">
                                        <TextBlock    Name="LabelGEO"
                                                      TextWrapping="Wrap"
                                                      Margin="20,-10"
                                                      Foreground="{DynamicResource PrimaryText}"
                                                      Style="{StaticResource  MaterialDesignBody2TextBlock}" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>

                            <Separator Margin="5,0,5,5" />

                            <RadioButton Height="40"
                                         Margin="5,0"
                                         FontSize="20"
                                         Foreground="{DynamicResource PrimaryText}"
                                         ToolTip="Iniciar grabación"
                                         Name="IA_Microfono"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Click="IA_Microfono_Click">
                                <RadioButton.Content>
                                    <Grid Margin="20,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition  Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 x:Name="Micro"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center" />
                                        <TextBlock Text="Grabadora"
                                                   Name="GrabadoraEstado"
                                                   Grid.Column="1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </Grid>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton Height="40"
                                         Margin="5,0"
                                         FontSize="20"
                                         Foreground="{DynamicResource PrimaryText}"
                                         ToolTip="Iniciar grabación"
                                         Name="PC_Microfono"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Click="PC_Microfono_Click">
                                <RadioButton.Content>
                                    <Grid Margin="20,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition  Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 x:Name="Micro2"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center" />
                                        <TextBlock Text="Grabadora PC"
                                                   Name="GrabadoraPCEstado"
                                                   Grid.Column="1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </Grid>
                                </RadioButton.Content>
                            </RadioButton>
                            <RadioButton Height="40"
                                         Margin="5,0"
                                         FontSize="20"
                                         Foreground="{DynamicResource PrimaryText}"
                                         ToolTip="Iniciar grabación de pantalla (sin sonido)"
                                         Name="PC_Film"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Click="PC_Film_Click">
                                <RadioButton.Content>
                                    <Grid Margin="20,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition  Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Width="20"
                                                                 Height="20"
                                                                 x:Name="Film"
                                                                 Foreground="{DynamicResource PrimaryText}"
                                                                 HorizontalAlignment="Center" />
                                        <TextBlock Text="Filmar PC"
                                                   Name="FilmadoraPCEstado"
                                                   Grid.Column="1"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0"
                                                   Foreground="{DynamicResource PrimaryText}" />
                                    </Grid>
                                </RadioButton.Content>
                            </RadioButton>
                            <Label Grid.Row="0"
                                   Margin="5,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryText}"
                                   Name="LabelEstado" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
            <UserControl Name="UC"
                         Grid.Row="0"
                         Grid.RowSpan="2"
                         Grid.Column="1" />


        </Grid>
    </Border>
</Window>
