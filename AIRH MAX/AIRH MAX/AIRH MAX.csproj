	<Target Name="RemoveSpecificRuntimes" AfterTargets="Build">
		<ItemGroup>
			<UnwantedRuntimes Include="&#xD;&#xA;      $(OutputPath)runtimes\android-arm;&#xD;&#xA;      $(OutputPath)runtimes\android-arm64;&#xD;&#xA;      $(OutputPath)runtimes\android-x64;&#xD;&#xA;      $(OutputPath)runtimes\android-x86;&#xD;&#xA;      $(OutputPath)runtimes\browser;&#xD;&#xA;      $(OutputPath)runtimes\browser-wasm;&#xD;&#xA;      $(OutputPath)runtimes\linux-arm;&#xD;&#xA;      $(OutputPath)runtimes\linux-arm64;&#xD;&#xA;      $(OutputPath)runtimes\linux-armel;&#xD;&#xA;      $(OutputPath)runtimes\linux-bionic-arm64;&#xD;&#xA;      $(OutputPath)runtimes\linux-bionic-x64;&#xD;&#xA;      $(OutputPath)runtimes\linux-mips64;&#xD;&#xA;      $(OutputPath)runtimes\linux-musl-arm;&#xD;&#xA;      $(OutputPath)runtimes\linux-musl-arm64;&#xD;&#xA;      $(OutputPath)runtimes\linux-musl-s390x;&#xD;&#xA;      $(OutputPath)runtimes\linux-musl-x64;&#xD;&#xA;      $(OutputPath)runtimes\linux-ppc64le;&#xD;&#xA;      $(OutputPath)runtimes\linux-s390x;&#xD;&#xA;      $(OutputPath)runtimes\linux-x64;&#xD;&#xA;      $(OutputPath)runtimes\linux-x86;&#xD;&#xA;      $(OutputPath)runtimes\maccatalyst-arm64;&#xD;&#xA;      $(OutputPath)runtimes\maccatalyst-x64;&#xD;&#xA;      $(OutputPath)runtimes\osx;&#xD;&#xA;      $(OutputPath)runtimes\osx-arm64;&#xD;&#xA;      $(OutputPath)runtimes\osx-x64;&#xD;&#xA;      $(OutputPath)runtimes\unix" />
		</ItemGroup>
		<RemoveDir Directories="@(UnwantedRuntimes)" />
	</Target>

	<Target Name="Obfuscate" AfterTargets="Build" Condition="'$(Configuration)' == 'Release' And '$(Platform)' == 'x64'">
		<Message Text="🔄 Ejecutando ofuscación con Obfuscar.Console.exe..." Importance="high" />

		<!-- ✅ Verificar que existan TODOS los archivos que se van a ofuscar -->
		<Error Condition="!Exists('$(OutDir)AIRH MAX.dll')" Text="❌ AIRH MAX.dll no encontrado en $(OutDir)" />
		<Error Condition="!Exists('$(OutDir)LLM_ServerMain.dll')" Text="❌ LLM_ServerMain.dll no encontrado en $(OutDir)" />
		<Error Condition="!Exists('$(OutDir)ErrorReportingNET.dll')" Text="❌ ErrorReportingNET.dll no encontrado en $(OutDir)" />
		<Error Condition="!Exists('$(OutDir)InfoSystem_v2.dll')" Text="❌ InfoSystem_v2.dll no encontrado en $(OutDir)" />
		<Error Condition="!Exists('$(OutDir)PiperSharp.dll')" Text="❌ PiperSharp.dll no encontrado en $(OutDir)" />
		<Error Condition="!Exists('$(OutDir)MAX.dll')" Text="❌ MAX.dll no encontrado en $(OutDir)" />
		<Error Condition="!Exists('$(OutDir)Vosk_STT.dll')" Text="❌ Vosk_STT.dll no encontrado en $(OutDir)" />

		<!-- ✅ Ejecutar Obfuscar -->
		<Exec Command="&quot;$(USERPROFILE)\.nuget\packages\obfuscar\2.2.49\tools\Obfuscar.Console.exe&quot; obfuscar.xml" WorkingDirectory="$(ProjectDir)" />

		<!-- ✅ Copiar DLLs ofuscadas de vuelta -->
		<ItemGroup>
			<ObfuscatedFiles Include="$(OutDir)obfuscated\*.dll" />
		</ItemGroup>
		<Copy SourceFiles="@(ObfuscatedFiles)" DestinationFolder="$(OutDir)" OverwriteReadOnlyFiles="true" />

		<!-- ✅ Limpiar carpeta temporal -->
		<RemoveDir Directories="$(OutDir)obfuscated\" />

		<Message Text="✅ DLLs ofuscadas copiadas a: $(OutDir)" Importance="high" />
	</Target>
