<Window x:Class="AIRH_MAX.Popups.Splash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ed="http://schemas.microsoft.com/expression/2010/drawing"
        mc:Ignorable="d"
        Title="Splash"
        Height="450"
        Width="300"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border CornerRadius="10"
                    Grid.RowSpan="2">
                <Border.Background>
                    <LinearGradientBrush>
                        <GradientStop Color="#FF02010F"
                                      Offset="0.0" />
                        <GradientStop Color="#FF020117"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <StackPanel VerticalAlignment="Center">
                <Grid>
                    <Ellipse Height="130"
                             Width="130"
                             StrokeThickness="10"
                             Stroke="{DynamicResource SecondaryColor}"
                             Opacity="0.3" />

                    <ed:Arc x:Name="ARC1"
                            Fill="{DynamicResource ColorProgress}"
                            Height="130"
                            Width="130"
                            Stretch="None"
                            ArcThickness="10"
                            ArcThicknessUnit="Pixel"
                            EndAngle="0">
                        <ed:Arc.Effect>
                            <DropShadowEffect Color="#FEF200"
                                              BlurRadius="10"
                                              RenderingBias="Quality"
                                              Direction="-90" />
                        </ed:Arc.Effect>
                    </ed:Arc>

                    <Image Height="200"
                           Width="200"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Source="{StaticResource Dial_Image}"
                           Stretch="Uniform" />


                    <TextBlock x:Name="LabelPorcentaje"
                               Text="0"
                               Foreground="{DynamicResource ColorProgress}"
                               FontSize="35"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,5,5">

                        <TextBlock.Effect>

                            <DropShadowEffect BlurRadius="30"
                                              ShadowDepth="2"
                                              Direction="-90"
                                              Color="#FEF200" />

                        </TextBlock.Effect>
                    </TextBlock>

                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Top">
                <TextBlock FontSize="15"
                           TextAlignment="Center"
                           Foreground="{DynamicResource ColorProgress}"
                           FontWeight="UltraLight"
                           VerticalAlignment="Center"
                           Name="LabelCarga"
                           HorizontalAlignment="Center">

                    <TextBlock.Effect>

                        <DropShadowEffect BlurRadius="15"
                                          ShadowDepth="2"
                                          Direction="-90"
                                          Color="#FEF200"/>

                    </TextBlock.Effect>
                </TextBlock>


            </StackPanel>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center">
                <TextBlock FontSize="25"
                           TextAlignment="Center"
                           Foreground="{DynamicResource PrimaryText}"
                           FontWeight="UltraLight"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"><Run Text="Asistente Virtual" /><LineBreak /><Run Text="AIRH" /><Run Language="es-es"
                                                                                                                             Text=" MAX" /></TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>

