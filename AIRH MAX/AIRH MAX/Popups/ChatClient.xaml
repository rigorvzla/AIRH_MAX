<Window x:Class="AIRH_MAX.Popups.ChatClient"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AIRH_MAX.Popups"
        xmlns:converters="clr-namespace:AIRH_MAX.ClassView"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Chat Moderno"
        Height="650"
        Width="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="ChatWindow_MouseLeftButtonDown"
        x:Name="ChatWindow">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ScrollBarModern.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:MessageMarginConverter x:Key="MessageMarginConverter" />
            <converters:BoolToSpanConverter x:Key="BoolToSpanConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverse" />
            <converters:StatusColorConverter x:Key="StatusColorConverter" />

            <!-- NUEVOS CONVERTERS AGREGADOS -->
            <converters:BoolToFontStyleConverter x:Key="BoolToFontStyleConverter" />
            <converters:BoolToFontSizeConverter x:Key="BoolToFontSizeConverter" />

            <!-- Estilos -->
            <Style x:Key="MessageBubbleStyle"
                   TargetType="Border">
                <Setter Property="CornerRadius"
                        Value="10" />
                <Setter Property="Padding"
                        Value="10" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="15"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="2"
                              Opacity="0.3" />
        </Border.Effect>
        <Border.Background>
            <RadialGradientBrush SpreadMethod="Reflect"
                                 Opacity="0.4"
                                 MappingMode="RelativeToBoundingBox">
                <GradientStop Color="#FF62629A" />
                <GradientStop Color="#FF39395A"
                              Offset="1" />
            </RadialGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="80" />
            </Grid.RowDefinitions>

            <!-- ==================== BARRA DE TÍTULO ==================== -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryColor}"
                    CornerRadius="15,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="AV-AIRH MAX"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0"
                               FontSize="16"
                               FontWeight="SemiBold" />

                    <!-- Panel de estado y contador -->
                    <Border Grid.Column="1"
                            Background="#F5F5F5"
                            Margin="15,10"
                            CornerRadius="8"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Height="25">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Indicador de estado -->
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,15,0">
                                <Ellipse Width="10"
                                         Height="10"
                                         Fill="{Binding StatusColor}"
                                         Margin="0,0,5,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="5"
                                                          Color="{Binding StatusColor.Color}"
                                                          Opacity="0.5"
                                                          ShadowDepth="0" />
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="{Binding ConnectionStatus}"
                                           Foreground="{Binding StatusColor}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </StackPanel>

                            <!-- Línea divisoria vertical -->
                            <Rectangle Grid.Column="1"
                                       Width="1"
                                       Height="25"
                                       Fill="#E0E0E0"
                                       VerticalAlignment="Center" />

                            <!-- Contador de usuarios -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="15,0,0,0">
                                <TextBlock Text="{Binding UserCount}"
                                           Foreground="#333"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="usuarios"
                                           Foreground="#666"
                                           FontSize="11"
                                           FontWeight="Normal"
                                           Margin="5,3,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Botones de control de ventana -->
                    <RadioButton Grid.Column="2"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="15"
                                 Width="30"
                                 Height="30"
                                 Margin="0,0,5,0"
                                 Foreground="{DynamicResource PrimaryText}"
                                 Command="{Binding MinimizeCommand}"
                                 Style="{StaticResource RadioButtomTheme}">
                        <RadioButton.Content>
                            <materialDesign:PackIcon Kind="Minus"
                                                     Width="25"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}" />
                        </RadioButton.Content>
                    </RadioButton>

                    <RadioButton Grid.Column="3"
                                 Margin="0,0,10,0"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Command="{Binding CloseCommand}"
                                 Style="{StaticResource RadioButtomTheme}"
                                 Foreground="{DynamicResource PrimaryText}"
                                 ToolTip="Cerrar ventana">

                        <RadioButton.Content>
                            <materialDesign:PackIcon Kind="Close"
                                                     Width="25"
                                                     Height="25"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{DynamicResource PrimaryText}" />
                        </RadioButton.Content>

                    </RadioButton>
                </Grid>
            </Border>

            <!-- Separador sutil -->
            <Rectangle Grid.Row="1"
                       Height="1"
                       Fill="#80FFFFFF"/>

            <!-- ==================== ÁREA DE MENSAJES ==================== -->
            <ScrollViewer Grid.Row="2"
                          Margin="10"
                          x:Name="MessageScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding MessageBackground}"
                                    CornerRadius="10"
                                    Margin="{Binding MessageAlignment, Converter={StaticResource MessageMarginConverter}}"
                                    Padding="10"
                                    HorizontalAlignment="{Binding MessageAlignment}"
                                    MaxWidth="350">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Nombre de usuario (oculto para mensajes del sistema) -->
                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="{Binding IsSystem, Converter={StaticResource BoolToSpanConverter}}"
                                               Text="{Binding UserName, StringFormat='{}{0}:'}"
                                               Foreground="{Binding UserNameColor}"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               HorizontalAlignment="{Binding MessageAlignment}"
                                               Margin="0,0,0,3"
                                               Visibility="{Binding IsSystem, Converter={StaticResource BoolToVisibilityInverse}}" />

                                    <!-- Texto del mensaje -->
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Text="{Binding Message}"
                                               Foreground="{Binding IsSystem, Converter={StaticResource StatusColorConverter}, ConverterParameter=text}"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="{Binding MessageAlignment}"
                                               Margin="0,0,5,0"
                                               FontStyle="{Binding IsSystem, Converter={StaticResource BoolToFontStyleConverter}}"
                                               FontSize="{Binding IsSystem, Converter={StaticResource BoolToFontSizeConverter}}" />

                                    <!-- Hora del mensaje (oculto para mensajes del sistema) -->
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding DisplayTime}"
                                               Foreground="#999"
                                               FontSize="9"
                                               VerticalAlignment="Bottom"
                                               Margin="5,0,0,0"
                                               Visibility="{Binding IsSystem, Converter={StaticResource BoolToVisibilityInverse}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ==================== ÁREA DE ESCRITURA ==================== -->
            <Border Grid.Row="3"
                    Background="{DynamicResource PrimaryColor}"
                    CornerRadius="0,0,15,15"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:Card Grid.Column="0"
                                         UniformCornerRadius="8"
                                         Background="White"
                                         Padding="0"
                                         Margin="10,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="1"
                                     x:Name="MessageTextBox"
                                     Height="40"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     BorderThickness="0"
                                     Text="{Binding CurrentMessage, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Escribe tu mensaje..."
                                     KeyDown="TextBox_KeyDown"
                                     Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                     IsEnabled="{Binding IsConnected}"
                                     Foreground="Black"
                                     SelectionBrush="{DynamicResource SecondaryText}"
                                     BorderBrush="{DynamicResource PrimaryText}">
                            </TextBox>
                        </Grid>
                    </materialDesign:Card>

                    <Button Grid.Column="1"
                            Width="50"
                            Height="50"
                            Margin="10,0,0,0"
                            Background="{DynamicResource PrimaryColor}"
                            BorderThickness="0"
                            FontSize="20"
                            Command="{Binding SendCommand}"
                            IsEnabled="{Binding CanSend}">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource MaterialDesignFlatButton}">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource PrimaryText}" />
                                <Setter Property="Content"
                                        Value="➤" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#80FFFFFF" />
                                        <Setter Property="Foreground"
                                                Value="White" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled"
                                             Value="False">
                                        <Setter Property="Foreground"
                                                Value="#80FFFFFF" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Overlay de carga/desconexión -->
            <Grid Grid.RowSpan="4" 
                  Background="#80000000"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="WebSync"
                                             HorizontalAlignment="Center"
                                             Width="50"
                                             Height="50"
                                             Foreground="White" />
                    <TextBlock Text="{Binding LoadingMessage}"
                               Foreground="White"
                               Margin="0,10,0,0"
                               FontSize="14"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>