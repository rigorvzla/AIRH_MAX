<UserControl x:Class="AIRH_MAX.ControlUsuario.Control_Gamer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Height="600"
             Width="700"
             Foreground="{DynamicResource PrimaryText}"
             Loaded="Window_Loaded">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ScrollBarModern.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid Grid.Row="0">
            <TabControl materialDesign:ColorZoneAssist.Background="Transparent"
                        materialDesign:ColorZoneAssist.Foreground="{DynamicResource PrimaryHueMidBrush}"
                        materialDesign:ColorZoneAssist.Mode="Custom"
                        Foreground="{DynamicResource PrimaryText}"
                        Style="{StaticResource MaterialDesignFilledTabControl}">

                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Teclado"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryText}" />
                    </TabItem.Header>

                    <Grid Grid.Row="3"
                          Name="G_Teclado"
                          Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition  Height="auto" />
                            <RowDefinition  Height="*" />
                            <RowDefinition  Height="auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid                            Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Margin="5"
                                             Grid.Column="0"
                                             Name="txbTeclaPresionada"
                                             Cursor="Arrow"
                                             CaretBrush="Transparent"
                                             FontWeight="Medium"
                                             Background="Transparent"
                                             TextWrapping="Wrap"
                                             PreviewKeyDown="TextBox_PreviewKeyUp"
                                             BorderThickness="0,0,0,1"
                                             Foreground="{DynamicResource PrimaryText}"
                                             SelectionBrush="{DynamicResource SecondaryText}"
                                             BorderBrush="{DynamicResource PrimaryText}"
                                             materialDesign:HintAssist.Hint="Asignar Tecla"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                                    <TextBox Margin="5"
                                             Grid.Column="1"
                                             IsReadOnly="True"
                                             Cursor="Arrow"
                                             Name="txbTeclaAsignada"
                                             Foreground="{DynamicResource PrimaryText}"
                                             SelectionBrush="{DynamicResource SecondaryText}"
                                             BorderBrush="{DynamicResource PrimaryText}"
                                             FontWeight="Medium"
                                             Background="Transparent"
                                             TextWrapping="Wrap"
                                             BorderThickness="0,0,0,1"
                                             materialDesign:HintAssist.Hint="Tecla Asignada"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                    <TextBox Margin="5"
                                             Grid.Column="2"
                                             Text="0"
                                             Cursor="Arrow"
                                             Foreground="{DynamicResource PrimaryText}"
                                             SelectionBrush="{DynamicResource SecondaryText}"
                                             BorderBrush="{DynamicResource PrimaryText}"
                                             PreviewKeyDown="txbTiempoPresion_PreviewKeyDown"
                                             Name="txbTiempoPresion"
                                             FontWeight="Medium"
                                             Background="Transparent"
                                             TextWrapping="Wrap"
                                             BorderThickness="0,0,0,1"
                                             materialDesign:HintAssist.Hint="Tiempo de Presion"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                    <ComboBox Name="lbJuegos"
                                              Margin="5"
                                              Grid.Column="3"
                                              VerticalAlignment="Bottom"
                                              Foreground="{DynamicResource SecondaryText}"
                                              materialDesign:HintAssist.Hint="Procesos"
                                              SelectionChanged="lbJuegos_SelectionChanged"
                                              MouseEnter="LbJuegos_MouseEnter"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                    </ComboBox>
                                </Grid>

                                <TextBox Grid.Row="2"
                                         Margin="5"
                                         FontWeight="Medium"
                                         Name="txbComando"
                                         Background="Transparent"
                                         TextWrapping="Wrap"
                                         BorderThickness="0,0,0,1"
                                         Foreground="{DynamicResource PrimaryText}"
                                         SelectionBrush="{DynamicResource SecondaryText}"
                                         BorderBrush="{DynamicResource PrimaryText}"
                                         materialDesign:HintAssist.Hint="Comando"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                <StackPanel Grid.Row="2"
                                            Margin="5"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                    <Button Width="30"
                                            Click="Button_Click"
                                            ToolTip="Guardar Comando"
                                            Foreground="{DynamicResource PrimaryText}"
                                            Padding="2,0,2,0"
                                            HorizontalAlignment="Right"
                                            materialDesign:RippleAssist.IsCentered="True"
                                            Style="{StaticResource MaterialDesignToolForegroundButton}">
                                        <materialDesign:PackIcon Kind="ContentSaveSettingsOutline" />
                                    </Button>

                                    <Button Width="30"
                                            Padding="2,0,2,0"
                                            Click="Button_Click_1"
                                            Foreground="{DynamicResource PrimaryText}"
                                            ToolTip="Borrar Comando"
                                            HorizontalAlignment="Right"
                                            materialDesign:RippleAssist.IsCentered="True"
                                            Style="{StaticResource MaterialDesignToolForegroundButton}">
                                        <materialDesign:PackIcon Kind="FileDocumentRemoveOutline" />
                                    </Button>
                                </StackPanel>
                            </Grid>

                        </StackPanel>
                        <DataGrid Name="dgComandos"
                                  Grid.Row="1"
                                  SelectionMode="Single"
                                  Background="AliceBlue"
                                  Foreground="Black"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  CanUserResizeRows="False"
                                  Margin="5"
                                  BorderBrush="Black"
                                  MaxColumnWidth="220"
                                  MinColumnWidth="10" />
                        <Grid Grid.Row="3"
                              Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <RadioButton Click="btnGuardar1_Click"
                                         Grid.Column="0"
                                         FontSize="13"
                                         FontWeight="SemiBold"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnGuardar1"
                                         MouseEnter="btnGuardar1_MouseEnter"
                                         MouseLeave="btnGuardar1_MouseLeave">
                                <StackPanel Orientation="Vertical">
                                    <Grid>
                                        <materialDesign:PackIcon Kind="FloppyDisc"
                                                                 Width="23"
                                                                 Height="25"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryText}" />
                                    </Grid>
                                    <TextBlock  Text="Guardar Perfil"
                                                Foreground="{DynamicResource PrimaryText}" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton FontSize="13"
                                         Grid.Column="1"
                                         Foreground="{DynamicResource PrimaryText}"
                                         Click="btnCargar_Click"
                                         FontWeight="SemiBold"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnCargar"
                                         MouseEnter="btnCargar_MouseEnter"
                                         MouseLeave="btnCargar_MouseLeave">
                                <StackPanel Orientation="Vertical">

                                    <Grid>
                                        <materialDesign:PackIcon Kind="Upload"
                                                                 Width="23"
                                                                 Height="25"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryText}" />
                                    </Grid>
                                    <TextBlock  Text="Cargar Perfil"
                                                Foreground="{DynamicResource PrimaryText}" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton FontSize="13"
                                         Grid.Column="2"
                                         Click="btnRestaurar_Click"
                                         FontWeight="SemiBold"
                                         Style="{StaticResource RadioButtomTheme}"
                                         Name="btnRestaurar"
                                         MouseEnter="btnRestaurar_MouseEnter"
                                         MouseLeave="btnRestaurar_MouseLeave">
                                <StackPanel Orientation="Vertical">
                                    <Grid>
                                        <materialDesign:PackIcon Kind="Recycle"
                                                                 Width="23"
                                                                 Height="25"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource PrimaryText}" />
                                    </Grid>

                                    <TextBlock  Text="Restaurar Perfil"
                                                Foreground="{DynamicResource PrimaryText}" />
                                </StackPanel>
                            </RadioButton>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Acción Automatica"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource PrimaryText}" />
                    </TabItem.Header>

                    <Grid>
                        <TabControl materialDesign:ColorZoneAssist.Background="Transparent"
                                    materialDesign:ColorZoneAssist.Foreground="{DynamicResource PrimaryHueMidBrush}"
                                    materialDesign:ColorZoneAssist.Mode="Custom"
                                    Foreground="{DynamicResource PrimaryText}"
                                    Style="{StaticResource MaterialDesignFilledTabControl}">

                            <TabItem>
                                <TabItem.Header>
                                    <TextBlock Text="Autokey"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryText}" />
                                </TabItem.Header>
                                <Grid>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition  Height="auto" />
                                            <RowDefinition  Height="*" />
                                            <RowDefinition  Height="auto" />
                                            <RowDefinition Height="auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid 
                                                            Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition />
                                                        <ColumnDefinition />
                                                        <ColumnDefinition />
                                                        <ColumnDefinition />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Margin="5"
                                                             Name="txbTeclaPresionadaAuto"
                                                             Grid.Column="0"
                                                             Cursor="Arrow"
                                                             FontWeight="Medium"
                                                             TextWrapping="Wrap"
                                                             PreviewKeyDown="TextBox_PreviewKeyUp1"
                                                             BorderThickness="0,0,0,1"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             SelectionBrush="{DynamicResource SecondaryText}"
                                                             BorderBrush="{DynamicResource PrimaryText}"
                                                             materialDesign:HintAssist.Hint="Asignar Tecla"
                                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

                                                    <TextBox Margin="5"
                                                             Grid.Column="1"
                                                             IsReadOnly="True"
                                                             Cursor="Arrow"
                                                             Name="txbTeclaAsignadaAuto"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             SelectionBrush="{DynamicResource SecondaryText}"
                                                             BorderBrush="{DynamicResource PrimaryText}"
                                                             FontWeight="Medium"
                                                             Background="Transparent"
                                                             TextWrapping="Wrap"
                                                             BorderThickness="0,0,0,1"
                                                             materialDesign:HintAssist.Hint="Tecla Asignada"
                                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                                    <TextBox Margin="5"
                                                             Grid.Column="2"
                                                             Cursor="Arrow"
                                                             PreviewKeyDown="txbTiempoPresion_PreviewKeyDown"
                                                             Name="txbTiempoAccion"
                                                             FontWeight="Medium"
                                                             Background="Transparent"
                                                             TextWrapping="Wrap"
                                                             BorderThickness="0,0,0,1"
                                                             Foreground="{DynamicResource PrimaryText}"
                                                             SelectionBrush="{DynamicResource SecondaryText}"
                                                             BorderBrush="{DynamicResource PrimaryText}"
                                                             materialDesign:HintAssist.Hint="Tiempo de Acción"
                                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                                    <ComboBox Name="lbJuegosAuto"
                                                              Margin="5"
                                                              Grid.Column="3"
                                                              VerticalAlignment="Bottom"
                                                              Foreground="{DynamicResource SecondaryText}"
                                                              materialDesign:HintAssist.Hint="Procesos"
                                                              SelectionChanged="lbJuegos_SelectionChanged2"
                                                              MouseEnter="LbJuegos_MouseEnter2"
                                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                                                </Grid>
                                                <CheckBox Grid.Row="2"
                                                          Margin="5,0,0,0"
                                                          Foreground="{DynamicResource PrimaryText}"
                                                          Background="{DynamicResource PrimaryText}"
                                                          Content="Secuencia"
                                                          Unchecked="chkSecuencia_Unchecked"
                                                          Checked="chkSecuencia_Checked"
                                                          Name="chkSecuencia" />
                                                <StackPanel Grid.Row="2"
                                                            Margin="5"
                                                            HorizontalAlignment="Right"
                                                            Orientation="Horizontal">
                                                    <Button Width="30"
                                                            Click="Button_Click2"
                                                            ToolTip="Guardar Comando"
                                                            Padding="2,0,2,0"
                                                            HorizontalAlignment="Right"
                                                            materialDesign:RippleAssist.IsCentered="True"
                                                            Style="{StaticResource MaterialDesignToolForegroundButton}">
                                                        <materialDesign:PackIcon Kind="ContentSaveSettingsOutline" />
                                                    </Button>

                                                    <Button Width="30"
                                                            Padding="2,0,2,0"
                                                            Click="Button_Click_2"
                                                            ToolTip="Borrar Comando"
                                                            HorizontalAlignment="Right"
                                                            materialDesign:RippleAssist.IsCentered="True"
                                                            Style="{StaticResource MaterialDesignToolForegroundButton}">
                                                        <materialDesign:PackIcon Kind="FileDocumentRemoveOutline" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                        </StackPanel>
                                        <DataGrid Name="dgComandosAuto"
                                                  Grid.Row="1"
                                                  SelectionMode="Single"
                                                  Background="AliceBlue"
                                                  Foreground="Black"
                                                  CanUserReorderColumns="False"
                                                  CanUserResizeColumns="False"
                                                  CanUserSortColumns="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  CanUserResizeRows="False"
                                                  Margin="5"
                                                  BorderBrush="Black"
                                                  MaxColumnWidth="220"
                                                  MinColumnWidth="10" />
                                        <Grid Grid.Row="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition />
                                            </Grid.ColumnDefinitions>
                                            <Button Content="Activar"
                                                    Margin="5"
                                                    Grid.Column="0"
                                                    Name="btnComenzar"
                                                    Foreground="{DynamicResource SecondaryText}"
                                                    BorderBrush="{DynamicResource SecondaryText}"
                                                    Click="btnComenzar_Click"
                                                    FontSize="13" />
                                            <Button Content="Desactivar"
                                                    Foreground="{DynamicResource SecondaryText}"
                                                    BorderBrush="{DynamicResource SecondaryText}"
                                                    Grid.Column="1"
                                                    Margin="5"
                                                    Name="btnDesactivar"
                                                    Click="btnDesactivar_Click"
                                                    FontSize="13"
                                                    FontWeight="SemiBold" />
                                        </Grid>

                                        <StackPanel Grid.Row="3">
                                            <Grid  Margin="5"
                                                   >
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition />
                                                    <ColumnDefinition />
                                                </Grid.ColumnDefinitions>

                                                <RadioButton Click="btnGuardar1_Click2"
                                                             Foreground="AliceBlue"
                                                             Grid.Column="0"
                                                             FontSize="13"
                                                             FontWeight="SemiBold"
                                                             Style="{StaticResource RadioButtomTheme}"
                                                             Name="btnGuardar1Auto"
                                                             MouseEnter="btnGuardar1_MouseEnter"
                                                             MouseLeave="btnGuardar1_MouseLeave">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid>
                                                            <materialDesign:PackIcon Kind="FloppyDisc"
                                                                                     Width="23"
                                                                                     Height="25"
                                                                                     HorizontalAlignment="Center"
                                                                                     VerticalAlignment="Center"
                                                                                     Foreground="{DynamicResource PrimaryText}" />
                                                        </Grid>
                                                        <TextBlock  Text="Guardar Perfil"
                                                                    Foreground="{DynamicResource PrimaryText}" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton FontSize="13"
                                                             Grid.Column="1"
                                                             Click="btnCargar_Click2"
                                                             FontWeight="SemiBold"
                                                             Style="{StaticResource RadioButtomTheme}"
                                                             Name="btnCargarAuto"
                                                             MouseEnter="btnCargar_MouseEnter"
                                                             MouseLeave="btnCargar_MouseLeave">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid>
                                                            <materialDesign:PackIcon Kind="Upload"
                                                                                     Width="23"
                                                                                     Height="25"
                                                                                     HorizontalAlignment="Center"
                                                                                     VerticalAlignment="Center"
                                                                                     Foreground="{DynamicResource PrimaryText}" />
                                                        </Grid>
                                                        <TextBlock  Text="Cargar Perfil"
                                                                    Foreground="{DynamicResource PrimaryText}" />
                                                    </StackPanel>
                                                </RadioButton>
                                                <RadioButton FontSize="13"
                                                             Grid.Column="2"
                                                             Click="btnRestaurar_Click2"
                                                             FontWeight="SemiBold"
                                                             Style="{StaticResource RadioButtomTheme}"
                                                             Name="btnRestaurarAuto"
                                                             MouseEnter="btnRestaurar_MouseEnter"
                                                             MouseLeave="btnRestaurar_MouseLeave">
                                                    <StackPanel Orientation="Vertical">
                                                        <Grid>
                                                            <materialDesign:PackIcon Kind="Recycle"
                                                                                     Width="23"
                                                                                     Height="25"
                                                                                     HorizontalAlignment="Center"
                                                                                     VerticalAlignment="Center"
                                                                                     Foreground="{DynamicResource PrimaryText}" />
                                                        </Grid>

                                                        <TextBlock    Foreground="{DynamicResource PrimaryText}"
                                                                      Text="Restaurar Perfil" />
                                                    </StackPanel>
                                                </RadioButton>

                                            </Grid>
                                            <TextBlock Margin="5"
                                                       Grid.Row="1"
                                                       Text="Cada vez que se cumpla el tiempo (Seg.) la &quot;Tecla&quot; será pulsada."
                                                       Background="{x:Null}"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"
                                                       Foreground="#FFE41919" />
                                        </StackPanel>
                                    </Grid>

                                </Grid>


                            </TabItem>
                            <TabItem>
                                <TabItem.Header>
                                    <TextBlock Text="AutoClick"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryText}" />
                                </TabItem.Header>
                                <Grid Cursor="Arrow">
                                    <Grid.RowDefinitions>
                                        <RowDefinition  Height="auto" />
                                        <RowDefinition  Height="auto" />
                                        <RowDefinition  Height="auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0"
                                                Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Name="cbTipoClick"
                                                  Margin="5"
                                                  Grid.Column="0"
                                                  VerticalAlignment="Bottom"
                                                  Foreground="{DynamicResource PrimaryText}"
                                                  materialDesign:HintAssist.Hint="Boton Mouse"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ComboBoxItem Content="Izquierdo" />
                                            <ComboBoxItem Content="Medio" />
                                            <ComboBoxItem Content="Derecho" />
                                        </ComboBox>
                                        <ComboBox Name="cbBotonMouse"
                                                  Margin="5"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Bottom"
                                                  Foreground="{DynamicResource PrimaryText}"
                                                  materialDesign:HintAssist.Hint="Tipo de Click"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ComboBoxItem Content="Click" />
                                            <ComboBoxItem Content="Doble Click" />
                                        </ComboBox>
                                        <ComboBox Name="lbJuegosClick"
                                                  IsEnabled="False"
                                                  Margin="5"
                                                  Grid.Column="2"
                                                  VerticalAlignment="Bottom"
                                                  Foreground="{DynamicResource PrimaryText}"
                                                  materialDesign:HintAssist.Hint="Procesos"
                                                  SelectionChanged="lbJuegos_SelectionChanged2"
                                                  MouseEnter="LbJuegos_MouseEnter2"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                                    </Grid>
                                    <Grid Grid.Row="1"
                                                Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                      
                                        <ComboBox Name="cbIntervalo"
                                                  Margin="5"
                                                  Grid.Column="0"
                                                  VerticalAlignment="Bottom"
                                                  Foreground="{DynamicResource PrimaryText}"
                                                  materialDesign:HintAssist.Hint="Tiempo de acción"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ComboBoxItem Content="Hora" />
                                            <ComboBoxItem Content="Minutos" />
                                            <ComboBoxItem Content="Segundos" />
                                            <ComboBoxItem Content="Milisegundos" />
                                        </ComboBox>
                                        <TextBox Margin="5"
                                                 Name="txbIntervalo"
                                                 Grid.Column="1"
                                                 VerticalAlignment="Bottom"
                                                 PreviewKeyDown="txbRepetir_PreviewKeyDown"
                                                 Cursor="Arrow"
                                                 Foreground="{DynamicResource PrimaryText}"
                                                 CaretBrush="Transparent"
                                                 FontWeight="Medium"
                                                 Background="Transparent"
                                                 TextWrapping="Wrap"
                                                 BorderThickness="0,0,0,1"
                                                 BorderBrush="AliceBlue"
                                                 materialDesign:HintAssist.Hint="Hora/Min/Seg/Mil"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                        <TextBox Margin="5"
                                                 Name="txbRepetir"
                                                 Grid.Column="2"
                                                 Foreground="{DynamicResource PrimaryText}"
                                                 Cursor="Arrow"
                                                 VerticalAlignment="Bottom"
                                                 ToolTip="Repeticion infinita (n)"
                                                 PreviewKeyDown="txbRepetir_PreviewKeyDown"
                                                 CaretBrush="Transparent"
                                                 FontWeight="Medium"
                                                 Background="Transparent"
                                                 TextWrapping="Wrap"
                                                 BorderThickness="0,0,0,1"
                                                 BorderBrush="AliceBlue"
                                                 materialDesign:HintAssist.Hint="Repetir"
                                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                    </Grid>
                                    <Grid Grid.Row="2"
                                          
                                                Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Button Margin="5"
                                                Name="btnStartClick"
                                                Grid.Column="0"
                                                Click="btnStartClick_Click"
                                                Content="Activar" />
                                        <Button Margin="5"
                                                Name="txbPosicionClick"
                                                Grid.Column="1"
                                                Click="txbPosicionClick_Click"
                                                Content="Posicion" />
                                        <Button Margin="5"
                                                Name="btnDetenerClick"
                                                Grid.Column="2"
                                                Click="btnDetenerClick_Click"
                                                Content="Desactivar" />
                                    </Grid>
                                </Grid>

                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>
            </TabControl>

        </Grid>
    </Grid>
</UserControl>
