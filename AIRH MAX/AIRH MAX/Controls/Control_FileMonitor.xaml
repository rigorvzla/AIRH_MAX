<UserControl x:Class="AIRH_MAX.ControlUsuario.Control_FileMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             Height="660"
             Width="700"
             Foreground="{DynamicResource PrimaryText}"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent"
             Loaded="Window_Loaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Theme/ScrollBarModern.xaml"></ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="464.269" />
            <RowDefinition Height="auto" />

        </Grid.RowDefinitions>

        <Label Content="Observador de Directorio"
               Margin="5"
               HorizontalAlignment="Center"
               Foreground="{DynamicResource PrimaryText}"
               FontWeight="SemiBold" />
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal">
            <TextBox Grid.Column="0"
                     FontWeight="Medium"
                     Width="650"
                     Focusable="False"
                     Margin="5"
                     Cursor="Arrow"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center"
                     Background="Transparent"
                     Name="TextBoxEnlace"
                     Foreground="{DynamicResource PrimaryText}"
                     SelectionBrush="{DynamicResource SecondaryText}"
                     BorderBrush="{DynamicResource PrimaryText}"
                     materialDesign:HintAssist.Hint="Directorio" />

            <Button ToolTip="Buscar Archivo"
                    Width="35"
                    Foreground="{DynamicResource PrimaryText}"
                    Style="{StaticResource CustomButton}"
                    Click="btnCaptura_Click"
                    BorderBrush="{x:Null}">
                <Grid>

                    <materialDesign:PackIcon Kind="FolderOpen"
                                             Width="23"
                                             Height="25"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource PrimaryText}" />
                </Grid>
            </Button>

        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Height="35"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center">
                <CheckBox Content="Creación"
                          Foreground="{DynamicResource PrimaryText}"
                          Background="{DynamicResource PrimaryText}"
                          FontWeight="SemiBold"
                          FontSize="14"
                          Name="cbCreado"
                          VerticalAlignment="Center" />

            </StackPanel>

            <StackPanel Grid.Column="1"
                        Height="35"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center">
                <CheckBox Content="Renombrado"
                          Foreground="{DynamicResource PrimaryText}"
                          Background="{DynamicResource PrimaryText}"
                          FontWeight="SemiBold"
                          FontSize="14"
                          Name="cbRenombrado"
                          VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Height="35"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center">
                <CheckBox Content="Modificado"
                          Foreground="{DynamicResource PrimaryText}"
                          Background="{DynamicResource PrimaryText}"
                          FontWeight="SemiBold"
                          FontSize="14"
                          Name="cbCambiado"
                          VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Height="35"
                        Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center">
                <CheckBox Content="Eliminado"
                          Foreground="{DynamicResource PrimaryText}"
                          Background="{DynamicResource PrimaryText}"
                          FontWeight="SemiBold"
                          FontSize="14"
                          Name="cbEliminar"
                          VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
        <RadioButton Grid.Row="3"
                     Content="Agregar directorio"
                     Height="30"
                     Width="auto"
                     Click="guardar_Click"
                     Foreground="{DynamicResource SecondaryText}"
                     BorderBrush="{DynamicResource SecondaryText}"
                     FontSize="13"
                     Margin="5"
                     FontWeight="SemiBold"
                     Style="{StaticResource MaterialDesignOutlinedDarkButton}" />
        <ListBox Grid.Row="4"
                 x:Name="lbRutas"
                 Margin="5"
                 Height="464"
                 Background="Transparent"
                 Foreground="{DynamicResource PrimaryText}"
                 BorderBrush="Transparent" />
        <RadioButton Grid.Row="5"
                     Content="Eliminar directorio"
                     Height="30"
                     Width="auto"
                     Click="eliminar_Click"
                     Foreground="{DynamicResource SecondaryText}"
                     BorderBrush="{DynamicResource SecondaryText}"
                     FontSize="13"
                     Margin="5"
                     FontWeight="SemiBold"
                     Style="{StaticResource MaterialDesignOutlinedDarkButton}" />

    </Grid>
</UserControl>
