<UserControl x:Class="AIRH_MAX.ControlUsuario.Banner.BannerMain"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIRH_MAX.ControlUsuario.Banner"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             Height="auto"
             Width="auto">

    <UserControl.Resources>
        <!-- Estilo idéntico al original, pero ahora con TextBlock como contenido -->
        <Style x:Key="BotonCustom"
               TargetType="Button">
            <Setter Property="OverridesDefaultStyle"
                    Value="True" />
            <Setter Property="Cursor"
                    Value="Arrow" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border"
                                BorderThickness="0"
                                BorderBrush="White"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Opacity"
                                        Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
            <StackPanel Orientation="Horizontal" Margin="5"
                        HorizontalAlignment="Center">

                <!-- Telegram -->
                <Button Width="20"
                        Height="20"
                        BorderThickness="0"
                        Click="RadioButton_Click"
                        FontWeight="Bold"
                        Style="{StaticResource BotonCustom}"
                        ToolTip="Desarrollador"
                        Margin="10,0,10,0"
                        Background="Transparent">
                    <Grid>
                        <materialDesign:PackIcon Kind="Telephone"
                                                 Width="20"
                                                 Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource PrimaryText}" />
                    </Grid>
                </Button>


                <!-- Web (Chrome) -->
                <Button Width="20"
                        Height="20"
                        BorderThickness="0"
                        Click="BtnWeb_Click"
                        Style="{StaticResource BotonCustom}"
                        FontWeight="Bold"
                        ToolTip="Web oficial"
                        Margin="10,0,10,0"
                        Background="Transparent">
                    <Grid>
                        <materialDesign:PackIcon Kind="Web"
                                                 Width="20"
                                                 Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource PrimaryText}" />
                    </Grid>
                </Button>


                <!-- YouTube -->
                <Button Width="20"
                        Height="20"
                        BorderThickness="0"
                        Style="{StaticResource BotonCustom}"
                        FontWeight="Bold"
                        Click="BtnYouTube_Click"
                        ToolTip="YouTube"
                        Margin="10,0,10,0"
                        Background="Transparent">
                    <Grid>
                        <materialDesign:PackIcon Kind="Youtube"
                                                 Width="20"
                                                 Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource PrimaryText}" />
                    </Grid>
                </Button>


                <!-- PayPal -->
                <Button Width="20"
                        Height="20"
                        BorderThickness="0"
                        Style="{StaticResource BotonCustom}"
                        FontWeight="Bold"
                        Click="BtnPaypal_Click"
                        ToolTip="Contribuye a esta noble causa"
                        Margin="10,0,10,0"
                        Background="Transparent">
                    <Grid>
                        <materialDesign:PackIcon Kind="Key"
                                                 Width="20"
                                                 Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource PrimaryText}" />
                    </Grid>
                </Button>


            </StackPanel>    
    </Grid>
</UserControl>