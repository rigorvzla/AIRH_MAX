<UserControl x:Class="AIRH_MAX.ControlUsuario.Control_Comentario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AIRH_MAX.ControlUsuario"
             mc:Ignorable="d"
             Height="600"
             Width="700">
    <Grid Margin="10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="COMENTARIO"
                   FontWeight="SemiBold"
                   Grid.Row="0"
                   Margin="5"
                   HorizontalAlignment="Center" />


        <StackPanel Grid.Row="1">
            <TextBlock Text="Correo Electronico*"
                       Margin="5,0"
                       FontWeight="SemiBold"
                       FontSize="13" />
            <TextBox Name="correo"
                     Margin="5,0" />
        </StackPanel>



        <TextBox x:Name="ComentarioBox"
                 AcceptsReturn="True"
                 Margin="5"
                 Grid.Row="2"
                 VerticalAlignment="Bottom"
                 VerticalScrollBarVisibility="Auto" />

        <Button Content="Enviar"
                Margin="5"
                Grid.Row="3"
                FontWeight="Normal"
                Click="Button_Click" />
    </Grid>
</UserControl>
