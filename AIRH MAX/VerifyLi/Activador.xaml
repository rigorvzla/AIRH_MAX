<Window x:Class="VerifyLi.Activador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VerifyLi"
        mc:Ignorable="d"
        Title="AIRH MAX - Licencias"
        Width="500"
        Height="750"
        MinWidth="400"
        MinHeight="600"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="HoverOpacityButtonStyle"
               TargetType="Button">
            <!-- Establece la apariencia original del botón -->
            <Setter Property="Background"
                    Value="#FF4CAF50" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#FF388E3C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="12,6" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!-- Establece la opacidad normal -->
            <Setter Property="Opacity"
                    Value="1" />

            <!-- Trigger para cambiar la opacidad al pasar el mouse -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Opacity"
                            Value="0.85" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0"
                  Focusable="False">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0"
                       Text="🔐 Activación y Solicitud de Licencia"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20" />

            <!-- Sección: Activar Licencia -->
            <GroupBox Grid.Row="1"
                      Header="✅ Activar Licencia"
                      Margin="0,0,0,15"
                      Padding="15"
                      BorderBrush="#3498DB"
                      BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Ingresa tu licencia:"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5" />
                    <TextBox Name="textLice"
                             Text="XXXXX-XXXXX-XXXXX-XXXXX"
                             Margin="0,0,0,10"
                             Style="{StaticResource MaterialDesignTextBox}"
                             Height="30"
                             FontSize="14"
                             TextWrapping="NoWrap"
                             Foreground="Black"
                             HorizontalAlignment="Stretch" />

                    <Button Content="Activar Licencia"
                            Click="Button_Click"
                            Background="#27AE60"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Padding="10,5"
                            Style="{StaticResource HoverOpacityButtonStyle}"
                            HorizontalAlignment="Right"
                            Width="120"
                            BorderThickness="0" />
                </StackPanel>
            </GroupBox>

            <!-- Sección: Solicitar Licencia -->
            <GroupBox Grid.Row="2"
                      Header="📩 Solicitar Nueva Licencia"
                      Margin="0,0,0,20"
                      Padding="15"
                      BorderBrush="#E67E22"
                      BorderThickness="1">
                <StackPanel Margin="10">
                    <TextBlock Text="Completa los siguientes datos para solicitar tu licencia:"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Foreground="#555" />

                    <TextBlock Text="Nombre completo:"
                               FontWeight="SemiBold" />
                    <TextBox Name="textnombre"
                             Style="{StaticResource MaterialDesignTextBox}"
                             Text="Juan Pérez"
                             Height="30"
                             FontSize="14" />

                    <TextBlock Text="Correo electrónico:"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold" />
                    <TextBox Name="textcorreo"
                             Text="tu@correo.com"
                             Style="{StaticResource MaterialDesignTextBox}"
                             Height="30"
                             FontSize="14" />

                    <TextBlock Text="Método de pago:"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold" />
                    <ComboBox Name="metodoPago"
                              Style="{StaticResource MaterialDesignComboBox}"
                              Height="30"
                              FontSize="14">
                        <ComboBoxItem Content="PayPal" />
                        <ComboBoxItem Content="Zinli" />
                        <ComboBoxItem Content="Pago Movil (Solo Venezuela)" />
                        <ComboBoxItem Content="Cripto (USDT)" />
                    </ComboBox>
                    <!-- Información de Pago - Clickeable -->
                    <GroupBox Grid.Row="3"
                              Header="💳 Dirección de Pago"
                              Name="groupPago"
                              Margin="0,15,0,15"
                              Padding="15"
                              BorderBrush="#27AE60"
                              BorderThickness="1"
                              Background="#F8FFF9"
                              Visibility="Collapsed"
                              MouseDown="groupPago_MouseDown"
                              Cursor="Hand">
                        <TextBlock Name="textDireccionPago"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="#2C3E50"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center" />
                    </GroupBox>
                    <TextBlock Text="Imagen del comprobante:"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold" />

                    <StackPanel Orientation="Horizontal">
                        <TextBox Name="textcomprobante"
                                 Height="30"
                                 Style="{StaticResource MaterialDesignTextBox}"
                                 Width="370"
                                 FontSize="14" />
                        <Button Content="..."
                                Height="30"
                                Width="30"
                                Margin="10,0"
                                Style="{StaticResource MaterialDesignFloatingActionButton}"
                                Click="Button_Click_2" />
                    </StackPanel>

                    <Button Content="Enviar Solicitud"
                            Click="Button_Click_1"
                            Background="#E67E22"
                            Foreground="White"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Padding="10,5"
                            HorizontalAlignment="Right"
                            Style="{StaticResource HoverOpacityButtonStyle}"
                            Width="120"
                            Margin="0,10"
                            BorderThickness="0" />
                </StackPanel>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</Window>
