<UserControl x:Class="SystemMonitorControls.CPU.LinealMD"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SystemMonitorControls.CPU"
             Loaded="UserControl_Loaded"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel>
        <TextBlock Name="txbcpu"
                   Margin="5"
                   HorizontalAlignment="Center" />
        <Grid Name="gridTotal">
            <Button HorizontalAlignment="Center"
                    Name="btnCPU"
                    Width="150"
                    Height="20"
                    Click="btnCPU_Click"
                    materialDesign:ButtonAssist.CornerRadius="10"
                    materialDesign:ButtonProgressAssist.IndicatorBackground="#FF767676"
                    materialDesign:ButtonProgressAssist.IndicatorForeground="#FF493E39"
                    materialDesign:ButtonProgressAssist.IsIndicatorVisible="True"
                    IsEnabled="{Binding DataContext.ControlsEnabled, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Visibility="{Binding ShowDismissButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Name="txbCPUP"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="12" />
                </StackPanel>
            </Button>
        </Grid>
        <TextBlock Name="txbCPU"
                   Margin="5"
                   HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
