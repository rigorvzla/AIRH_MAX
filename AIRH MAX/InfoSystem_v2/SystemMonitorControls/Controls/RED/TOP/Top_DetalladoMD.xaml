<Window x:Class="SystemMonitorControls.RED.TOP.Top_DetalladoMD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SystemMonitorControls.RED.TOP"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Loaded="Window_Loaded"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStyle="None"
        Closed="Window_Closed"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        Title="Monitor de Red"
        Height="550"
        Width="800">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="BlueGrey"
                                             SecondaryColor="Blue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Estilo para botones de ventana modernos -->
            <Style x:Key="ModernWindowButton"
                   TargetType="Button">
                <Setter Property="Width"
                        Value="32" />
                <Setter Property="Height"
                        Value="32" />
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="BorderBrush"
                        Value="Transparent" />
                <Setter Property="Foreground"
                        Value="White" />
                <Setter Property="Cursor"
                        Value="Hand" />
                <Setter Property="materialDesign:RippleAssist.Feedback"
                        Value="White" />
                <Setter Property="materialDesign:RippleAssist.IsCentered"
                        Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="BackgroundEllipse"
                                         Fill="{TemplateBinding Background}"
                                         Stroke="{TemplateBinding BorderBrush}" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="BackgroundEllipse"
                                            Property="Fill">
                                        <Setter.Value>
                                            <SolidColorBrush Color="White"
                                                             Opacity="0.2" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed"
                                         Value="True">
                                    <Setter TargetName="BackgroundEllipse"
                                            Property="Fill">
                                        <Setter.Value>
                                            <SolidColorBrush Color="White"
                                                             Opacity="0.3" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Estilo para la gráfica -->
            <Style TargetType="lvc:CartesianChart">
                <Setter Property="Background"
                        Value="Transparent" />
                <Setter Property="Foreground"
                        Value="AliceBlue" />
                <Setter Property="TooltipPosition"
                        Value="Top" />
                <Setter Property="LegendPosition"
                        Value="Right" />
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="15"
            Background="#FF02010F"
            Effect="{StaticResource MaterialDesignShadowDepth4}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Barra de título moderna -->
            <Grid Grid.Row="0"
                  Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Network"
                                             Foreground="#81d4fa"
                                             Width="20"
                                             Height="20" />
                    <TextBlock Text=" RED TOP - Monitoreo de Red"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="8,0,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,15,0">
                    <Button Click="Button_Click"
                            Style="{StaticResource ModernWindowButton}"
                            ToolTip="Minimizar">
                        <materialDesign:PackIcon Kind="WindowMinimize"
                                                 Width="14"
                                                 Height="14"
                                                 Foreground="White" />
                    </Button>

                    <Button Click="Button_Click_1"
                            Style="{StaticResource ModernWindowButton}"
                            ToolTip="Cerrar"
                            Margin="5,0,0,0">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="14"
                                                 Height="14"
                                                 Foreground="White" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Panel de información de red -->
            <Border Grid.Row="1"
                    Background="#20FFFFFF"
                    CornerRadius="12"
                    Margin="15,10,15,10"
                    Padding="15,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ArrowUpBold"
                                                 Foreground="#ff6b6b"
                                                 Width="22"
                                                 Height="22" />
                        <TextBlock Text=" Velocidad de Subida"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="ArrowDownBold"
                                                 Foreground="#51cf66"
                                                 Width="22"
                                                 Height="22" />
                        <TextBlock Text=" Velocidad de Bajada"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Update"
                                                 Foreground="#81d4fa"
                                                 Width="22"
                                                 Height="22" />
                        <TextBlock Text=" Actualización en Tiempo Real"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Contenedor de la gráfica -->
            <Border Grid.Row="2"
                    Background="Transparent"
                    CornerRadius="12"
                    Margin="15,5,15,15"
                    Padding="10">
                <Border Background="#10FFFFFF"
                        CornerRadius="12"
                        Padding="15">
                    <lvc:CartesianChart Name="graf"
                                        Background="Transparent"
                                        EasingFunction="{x:Null}"
                                        TooltipPosition="Top"
                                        LegendPosition="Right"
                                        Height="380">
                    </lvc:CartesianChart>
                </Border>
            </Border>

            <!-- Barra de estado con información -->
            <Border Grid.Row="2"
                    VerticalAlignment="Bottom"
                    Height="30"
                    Background="Transparent"
                    Margin="20,0,20,15">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Information"
                                             Foreground="#60FFFFFF"
                                             Width="12"
                                             Height="12"
                                             Margin="0,0,5,0" />
                    <TextBlock Text="📊 Monitoreo de red en tiempo real | Subida (Rojo) - Bajada (Verde)"
                               Foreground="#60FFFFFF"
                               FontSize="10"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>