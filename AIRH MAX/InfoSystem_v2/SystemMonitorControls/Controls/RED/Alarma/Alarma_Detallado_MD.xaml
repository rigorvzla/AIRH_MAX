<Window x:Class="SystemMonitorControls.RED.Alarma.Alarma_Detallado_MD"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SystemMonitorControls.RED.Alarma"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="Alarma RED"
        Height="340"
        Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="5">
            <TextBlock Foreground="Black"
                       FontWeight="SemiBold"
                       TextAlignment="Center"><Run Text="Escribe " /><Run Language="es-es"
                                                                          Text="el rango" /><Run Text=" " /><LineBreak /><Run Text="para recibir la alerta " /></TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="5">
            <TextBlock  TextWrapping="Wrap"
                        Text="Subida"
                        Width="145"
                        Height="39"
                        TextAlignment="Center" />
            <TextBox x:Name="txt_Subida"
                     Text="0"
                     Width="50"
                     TextAlignment="Center"
                     MaxLength="4"
                     PreviewKeyDown="TxtHDD_PreviewKeyDown" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="5">
            <TextBlock  TextWrapping="Wrap"
                        Text="Bajada"
                        Width="145"
                        Height="39"
                        TextAlignment="Center" />
            <TextBox x:Name="txt_CargaHDD"
                     Text="0"
                     Width="50"
                     TextAlignment="Center"
                     MaxLength="4"
                     PreviewKeyDown="TxtHDD_PreviewKeyDown" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="5">
            <CheckBox Content="Activar"
                      Name="cbActivar"
                      Checked="CheckBox_Checked"
                      Margin="5"
                      Unchecked="cbActivar_Unchecked"
                      HorizontalAlignment="Center" />
            <TextBlock x:Name="txt_valorsubida"
                       Margin="5"
                       Text="0"
                       TextAlignment="Center" />
            <TextBlock x:Name="txt_valorbajada"
                       Margin="5"
                       Text="0"
                       TextAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Margin="5">
            <Button Content="Reinicio"
                    Click="Button_Click" />
        </StackPanel>
    </Grid>
</Window>
